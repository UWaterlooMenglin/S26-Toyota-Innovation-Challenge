SERVER_HOST_IP_ADDRESS="127.0.0.1"  # IP for laptop running central-arbiter.py
SERVER_PORT="9000"

# Robot Identifier
ROBOT_ID="robot_A"
CLIENT_NAME="robot_A_laptop"
USE_WIFI_BRIDGE=true               # Change to 'true' if using ESP32 Enabled Robot

# Wired Settings
LOCAL_SERIAL_PORT="/dev/ttyUSB0"            # COM Port for wired (or /dev/ttyACM0)
SERIAL_BAUD="115200"

# Wireless Settings
ESP32_HOST=10.37.86.5              # IP Address of the ESP32
ESP32_PORT=81